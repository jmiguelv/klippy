---
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Klippy — King's Digital Lab</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://unpkg.com/open-props/open-props.min.css"
        />
    </head>
    <body>
        <div class="page-rule" aria-hidden="true"></div>

        <nav>
            <div class="nav-inner">
                <a href="/" class="nav-wordmark">Klippy</a>
            </div>
        </nav>

        <main>
            <header class="hero">
                <p class="hero-eyebrow">King's Digital Lab</p>
                <h1 class="hero-heading">
                    Ask anything about<br />your research projects.
                </h1>
                <p class="hero-sub">
                    Search across ClickUp tasks, GitHub repositories,<br
                        class="break"
                    />
                    and internal documentation.
                </p>
            </header>

            <section class="query-section">
                <div class="query-wrapper" id="query-wrapper">
                    <label class="query-label" for="search-input">Query</label>
                    <div class="query-input-row">
                        <input
                            type="text"
                            id="search-input"
                            placeholder=""
                            autocomplete="off"
                            spellcheck="false"
                        />
                        <button id="search-button" aria-label="Execute query">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            <span>Search</span>
                        </button>
                    </div>
                    <p class="query-hint">Press <kbd>↵ Enter</kbd> to search</p>
                </div>
            </section>

            <section id="results-section" class="results hidden">
                <div id="loader" class="loader hidden">
                    <div class="loader-bar">
                        <div class="loader-progress"></div>
                    </div>
                    <p class="loader-label">
                        <span id="loader-verb">Synthesising</span><span
                            id="ellipsis"></span>
                    </p>
                </div>

                <article id="answer-block" class="answer-block">
                    <header class="answer-meta">
                        <div class="answer-meta-left">
                            <span class="answer-tag">Synthesis</span>
                            <span id="cache-badge" class="cache-badge hidden"
                            ></span>
                        </div>
                        <span id="query-time" class="query-time"></span>
                    </header>
                    <div id="answer-content" class="answer-content markdown-body"></div>
                    <footer class="answer-footer">
                        <span class="answer-footer-label"
                            >Sources: ClickUp · GitHub</span
                        >
                    </footer>
                </article>
            </section>
        </main>

        <footer class="site-footer">
            <div class="footer-inner">
                <span class="footer-brand">King's Digital Lab</span>
                <span class="footer-stack"
                    >LlamaIndex · Qdrant · Redis · Arize Phoenix</span
                >
            </div>
        </footer>

        <style>
            /* ── Reset ──────────────────────────────────────── */
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            /* ── Tokens ─────────────────────────────────────── */
            :root {
                --kings-red: #d6001c;
                --kings-red-light: #f2e5e7;
                --canvas: #faf9f7;
                --surface: #ffffff;
                --border: #e2ddd8;
                --border-dark: #c8c2bb;

                --ink-0: #1a1614;
                --ink-1: #3d3733;
                --ink-2: #7a7470;

                --teal: #1f7a6e;
                --teal-light: #e0f0ee;

                /* Typography */
                --font-display: "Cormorant Garamond", Georgia, serif;
                --font-sans: "IBM Plex Sans", system-ui, sans-serif;
                --font-mono: "IBM Plex Mono", "Courier New", monospace;
            }

            /* ── Base ───────────────────────────────────────── */
            html {
                background-color: var(--canvas);
            }

            body {
                font-family: var(--font-sans);
                color: var(--ink-0);
                background-color: var(--canvas);
                min-height: 100svh;
                display: flex;
                flex-direction: column;
                -webkit-font-smoothing: antialiased;
            }

            .page-rule {
                height: 3px;
                background: var(--kings-red);
            }

            nav {
                border-bottom: 1px solid var(--border);
                background: var(--surface);
            }

            .nav-inner {
                max-width: 1040px;
                margin: 0 auto;
                padding: 0 var(--size-6);
                height: 56px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .nav-wordmark {
                font-family: var(--font-display);
                font-size: 1.4rem;
                font-weight: 600;
                color: var(--ink-0);
                text-decoration: none;
                letter-spacing: 0.02em;
            }

            main {
                flex: 1;
                max-width: 1040px;
                width: 100%;
                margin: 0 auto;
                padding: var(--size-12) var(--size-6) var(--size-10);
                display: flex;
                flex-direction: column;
                gap: var(--size-10);
            }

            .hero {
                max-width: 680px;
                display: flex;
                flex-direction: column;
                gap: var(--size-4);
            }

            .hero-eyebrow {
                font-family: var(--font-mono);
                font-size: 0.7rem;
                font-weight: 400;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--kings-red);
            }

            .hero-heading {
                font-family: var(--font-display);
                font-size: clamp(2.4rem, 5vw, 3.8rem);
                font-weight: 500;
                line-height: 1.12;
                color: var(--ink-0);
                letter-spacing: -0.01em;
            }

            .hero-sub {
                font-size: 0.95rem;
                font-weight: 300;
                color: var(--ink-2);
                line-height: 1.65;
                max-width: 560px;
            }

            .query-section {
                max-width: 680px;
            }

            .query-wrapper {
                display: flex;
                flex-direction: column;
                gap: var(--size-3);
                padding: var(--size-6) var(--size-7);
                background: var(--surface);
                border: 1px solid var(--border);
                border-top: 3px solid var(--kings-red);
                transition: box-shadow 0.2s;
            }

            .query-wrapper:focus-within {
                box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
            }

            .query-label {
                font-family: var(--font-mono);
                font-size: 0.65rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--kings-red);
                display: block;
            }

            .query-input-row {
                display: flex;
                align-items: center;
                gap: var(--size-4);
                border-bottom: 1px solid var(--border-dark);
                padding-bottom: var(--size-3);
                transition: border-color 0.2s;
            }

            .query-wrapper:focus-within .query-input-row {
                border-color: var(--ink-0);
            }

            #search-input {
                flex: 1;
                background: transparent;
                border: none;
                outline: none;
                font-family: var(--font-sans);
                font-size: 1.05rem;
                font-weight: 300;
                color: var(--ink-0);
                caret-color: var(--kings-red);
                min-width: 0;
            }

            #search-button {
                display: inline-flex;
                align-items: center;
                gap: var(--size-2);
                background: var(--kings-red);
                color: #ffffff;
                border: none;
                padding: var(--size-2) var(--size-4);
                font-family: var(--font-sans);
                font-size: 0.8rem;
                font-weight: 500;
                letter-spacing: 0.02em;
                cursor: pointer;
                transition: background 0.15s;
                flex-shrink: 0;
                white-space: nowrap;
            }

            .results {
                max-width: 680px;
                display: flex;
                flex-direction: column;
                gap: var(--size-5);
            }

            .results.hidden {
                display: none;
            }

            .loader {
                display: flex;
                flex-direction: column;
                gap: var(--size-3);
            }

            .loader.hidden {
                display: none;
            }

            .loader-bar {
                height: 2px;
                background: var(--border);
                position: relative;
                overflow: hidden;
            }

            .loader-progress {
                position: absolute;
                top: 0;
                left: -35%;
                width: 35%;
                height: 100%;
                background: var(--kings-red);
                animation: scan 1.3s ease-in-out infinite;
            }

            @keyframes scan {
                0% { left: -35%; }
                100% { left: 100%; }
            }

            .answer-block {
                background: var(--surface);
                border: 1px solid var(--border);
                border-left: 3px solid var(--kings-red);
                opacity: 0;
                transform: translateY(6px);
                transition: opacity 0.35s ease, transform 0.35s ease;
                display: none;
            }

            .answer-block.visible {
                opacity: 1;
                transform: translateY(0);
                display: block;
            }

            .answer-meta {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: var(--size-4) var(--size-6);
                border-bottom: 1px solid var(--border);
                background: var(--canvas);
            }

            .answer-meta-left {
                display: flex;
                align-items: center;
                gap: var(--size-3);
            }

            .answer-tag {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                font-weight: 500;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: var(--kings-red);
            }

            .cache-badge {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                font-weight: 400;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                padding: 2px var(--size-2);
                border: 1px solid;
            }

            .cache-badge.hidden {
                display: none;
            }

            .cache-badge--cached {
                color: var(--teal);
                border-color: var(--teal);
                background: var(--teal-light);
            }

            .cache-badge--fresh {
                color: var(--ink-2);
                border-color: var(--border-dark);
            }

            .query-time {
                font-family: var(--font-mono);
                font-size: 0.65rem;
                color: var(--ink-2);
                font-weight: 300;
            }

            .answer-content {
                font-family: var(--font-display);
                font-size: 1.2rem;
                font-weight: 400;
                line-height: 1.75;
                color: var(--ink-0);
                padding: var(--size-7) var(--size-6);
            }

            /* Markdown Styling */
            .markdown-body h1, .markdown-body h2, .markdown-body h3 {
                margin-top: 1.5rem;
                margin-bottom: 1rem;
                font-family: var(--font-sans);
                font-weight: 600;
                color: var(--kings-red);
            }
            .markdown-body h1 { font-size: 1.4rem; }
            .markdown-body h2 { font-size: 1.2rem; }
            .markdown-body h3 { font-size: 1.1rem; }
            
            .markdown-body p { margin-bottom: 1.25rem; }
            
            .markdown-body ul, .markdown-body ol {
                margin-bottom: 1.25rem;
                padding-left: 1.5rem;
            }
            
            .markdown-body li { margin-bottom: 0.5rem; }
            
            .markdown-body a {
                color: var(--kings-red);
                text-decoration: underline;
                text-underline-offset: 2px;
            }
            
            .markdown-body code {
                font-family: var(--font-mono);
                font-size: 0.9rem;
                background: var(--canvas);
                padding: 2px 4px;
                border-radius: 4px;
            }

            .answer-content.error {
                font-family: var(--font-mono);
                font-size: 0.8rem;
                color: var(--kings-red);
                font-weight: 300;
            }

            .answer-footer {
                padding: var(--size-3) var(--size-6);
                border-top: 1px solid var(--border);
            }

            .answer-footer-label {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--ink-2);
                font-weight: 300;
                letter-spacing: 0.05em;
            }

            .site-footer {
                border-top: 1px solid var(--border);
                background: var(--surface);
                margin-top: auto;
            }

            .footer-inner {
                max-width: 1040px;
                margin: 0 auto;
                padding: var(--size-4) var(--size-6);
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .footer-brand {
                font-family: var(--font-display);
                font-size: 0.9rem;
                color: var(--ink-1);
                font-style: italic;
            }

            .footer-stack {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--ink-2);
                letter-spacing: 0.1em;
                text-transform: uppercase;
                font-weight: 300;
            }

            @media (max-width: 640px) {
                main { padding: var(--size-8) var(--size-4) var(--size-8); gap: var(--size-8); }
                .hero-sub .break { display: none; }
                .query-wrapper { padding: var(--size-5) var(--size-5); }
                .query-input-row { flex-wrap: wrap; gap: var(--size-3); }
                #search-button { width: 100%; justify-content: center; padding: var(--size-3); }
                .footer-inner { flex-direction: column; gap: var(--size-2); text-align: center; }
            }
        </style>

        <script>
            import { marked } from 'marked';

            const PLACEHOLDERS = [
                "What is the current status of the Musical Lives project?",
                "Which GitHub repositories are linked to the Sudan Memory project?",
                "Who is leading the Enlightenment Architectures project?",
                "What tasks are open in the Digital Humanities sprint?",
                "Summarise recent commits to the klippy repository.",
                "Which projects are due to end this year?",
                "What are the main research themes across active projects?",
            ];

            const searchInput = document.getElementById("search-input") as HTMLInputElement;
            const searchButton = document.getElementById("search-button") as HTMLButtonElement;
            const resultsSection = document.getElementById("results-section") as HTMLElement;
            const loader = document.getElementById("loader") as HTMLElement;
            const answerBlock = document.getElementById("answer-block") as HTMLElement;
            const answerContent = document.getElementById("answer-content") as HTMLElement;
            const cacheBadge = document.getElementById("cache-badge") as HTMLElement;
            const ellipsis = document.getElementById("ellipsis") as HTMLElement;
            const queryTime = document.getElementById("query-time") as HTMLElement;
            const loaderVerb = document.getElementById("loader-verb") as HTMLElement;

            function rotatePlaceholder() {
                let current = 0;
                let charIndex = 0;
                let isDeleting = false;
                let isPaused = false;

                function tick() {
                    if (document.activeElement === searchInput) return;
                    const target = PLACEHOLDERS[current];
                    if (isPaused) return;

                    if (!isDeleting) {
                        searchInput.placeholder = target.slice(0, ++charIndex);
                        if (charIndex === target.length) {
                            isPaused = true;
                            setTimeout(() => { isPaused = false; isDeleting = true; tick(); }, 2800);
                            return;
                        }
                        setTimeout(tick, 38);
                    } else {
                        searchInput.placeholder = target.slice(0, --charIndex);
                        if (charIndex === 0) {
                            isDeleting = false;
                            current = (current + 1) % PLACEHOLDERS.length;
                            setTimeout(tick, 400);
                            return;
                        }
                        setTimeout(tick, 18);
                    }
                }
                setTimeout(tick, 600);
            }

            rotatePlaceholder();

            const LOADER_VERBS = ["Transcribing", "Annotating", "Collating", "Paleographing", "Hermeneuticising", "Disambiguating", "Contextualising", "Cross-referencing", "Lemmatising", "Deciphering", "Indexing", "Triangulating"];
            let loaderVerbInterval: any = null;
            let ellipsisInterval: any = null;

            function startLoadingEffects() {
                let i = Math.floor(Math.random() * LOADER_VERBS.length);
                loaderVerb.textContent = LOADER_VERBS[i];
                loaderVerbInterval = setInterval(() => {
                    i = (i + 1) % LOADER_VERBS.length;
                    loaderVerb.textContent = LOADER_VERBS[i];
                }, 3000);

                let count = 0;
                ellipsisInterval = setInterval(() => {
                    count = (count + 1) % 4;
                    ellipsis.textContent = ".".repeat(count);
                }, 380);
            }

            function stopLoadingEffects() {
                clearInterval(loaderVerbInterval);
                clearInterval(ellipsisInterval);
                ellipsis.textContent = "";
            }

            function resetResults() {
                answerBlock.classList.remove("visible");
                answerBlock.style.display = "none";
                answerContent.innerHTML = "";
                answerContent.classList.remove("error");
                cacheBadge.className = "cache-badge hidden";
                queryTime.textContent = "";
            }

            async function handleSearch() {
                const query = searchInput.value.trim();
                if (!query) return;

                resetResults();
                resultsSection.classList.remove("hidden");
                loader.classList.remove("hidden");
                startLoadingEffects();

                const startTime = Date.now();

                try {
                    const response = await fetch("http://localhost:8000/query", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ text: query }),
                    });

                    const data = await response.json();
                    const elapsed = Date.now() - startTime;

                    stopLoadingEffects();
                    loader.classList.add("hidden");

                    answerBlock.style.display = "block";
                    void answerBlock.offsetHeight;
                    answerBlock.classList.add("visible");

                    cacheBadge.classList.remove("hidden");
                    if (data.cached) {
                        cacheBadge.textContent = "⚡ Cached";
                        cacheBadge.classList.add("cache-badge--cached");
                    } else {
                        cacheBadge.textContent = "Fresh";
                        cacheBadge.classList.add("cache-badge--fresh");
                    }

                    queryTime.textContent = `${elapsed}ms`;
                    
                    // Render Markdown
                    answerContent.innerHTML = await marked.parse(data.answer);
                    
                } catch (error) {
                    const elapsed = Date.now() - startTime;
                    stopLoadingEffects();
                    loader.classList.add("hidden");
                    answerBlock.style.display = "block";
                    void answerBlock.offsetHeight;
                    answerBlock.classList.add("visible");
                    answerContent.classList.add("error");
                    answerContent.textContent = "Error: Could not connect to backend at localhost:8000";
                    queryTime.textContent = `${elapsed}ms`;
                }
            }

            searchButton.addEventListener("click", handleSearch);
            searchInput.addEventListener("keydown", (e: KeyboardEvent) => {
                if (e.key === "Enter") handleSearch();
            });
        </script>
    </body>
</html>
