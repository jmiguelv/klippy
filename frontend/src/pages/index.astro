---
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Klippy — King's Digital Lab</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://unpkg.com/open-props/open-props.min.css"
        />
    </head>
    <body>
        <div class="page-rule" aria-hidden="true"></div>

        <nav>
            <div class="nav-inner">
                <a href="/" class="nav-wordmark">Klippy</a>
            </div>
        </nav>

        <main>
            <header class="hero">
                <p class="hero-eyebrow">King's Digital Lab</p>
                <h1 class="hero-heading">
                    Ask anything about<br />your research projects.
                </h1>
                <p class="hero-sub">
                    Search across ClickUp tasks, GitHub repositories,<br
                        class="break"
                    />
                    and internal documentation.
                </p>
            </header>

            <section class="query-section">
                <div class="query-wrapper" id="query-wrapper">
                    <label class="query-label" for="search-input">Query</label>
                    <div class="query-input-row">
                        <input
                            type="text"
                            id="search-input"
                            placeholder=""
                            autocomplete="off"
                            spellcheck="false"
                        />
                        <button id="search-button" aria-label="Execute query">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            <span>Search</span>
                        </button>
                    </div>
                    <p class="query-hint">Press <kbd>↵ Enter</kbd> to search</p>
                </div>
            </section>

            <section id="results-section" class="results hidden">
                <div id="loader" class="loader hidden">
                    <div class="loader-bar">
                        <div class="loader-progress"></div>
                    </div>
                    <p class="loader-label">
                        <span id="loader-verb">Synthesising</span><span
                            id="ellipsis"></span>
                    </p>
                </div>

                <article id="answer-block" class="answer-block">
                    <header class="answer-meta">
                        <div class="answer-meta-left">
                            <span class="answer-tag">Synthesis</span>
                            <span id="cache-badge" class="cache-badge hidden"></span>
                            <span id="cache-date" class="cache-date hidden"></span>
                        </div>
                        <div class="answer-meta-right">
                            <div class="feedback-tools">
                                <button id="thumbs-up" class="feedback-btn" title="Helpful answer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10v12"></path><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"></path></svg>
                                </button>
                                <button id="thumbs-down" class="feedback-btn" title="Not helpful (clears cache)">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"></path><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22h0a3.13 3.13 0 0 1-3-3.88Z"></path></svg>
                                </button>
                                <div class="feedback-sep"></div>
                                <button id="refresh-query" class="feedback-btn" title="Refresh (ignore cache)">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path><path d="M21 3v5h-5"></path><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path><path d="M3 21v-5h5"></path></svg>
                                </button>
                            </div>
                            <div id="timing-breakdown" class="timing-breakdown hidden">
                                <span title="Retrieval time">R: <span id="retrieval-time"></span>ms</span>
                                <span class="timing-sep">|</span>
                                <span title="LLM Synthesis time">S: <span id="synthesis-time"></span>ms</span>
                            </div>
                            <span id="query-time" class="query-time"></span>
                        </div>
                    </header>
                    <div id="answer-content" class="answer-content markdown-body"></div>
                    <footer class="answer-footer" id="answer-footer">
                        <button class="sources-toggle" id="sources-toggle">
                            <span class="sources-toggle-label">Referenced Sources</span>
                            <span class="sources-toggle-icon" id="sources-toggle-icon">▼</span>
                        </button>
                        <div id="sources-container" class="sources-list"></div>
                    </footer>
                </article>
            </section>
        </main>

        <footer class="site-footer">
            <div class="footer-inner">
                <span class="footer-brand">King's Digital Lab</span>
                <span class="footer-stack"
                    >LlamaIndex · Qdrant · Redis · Arize Phoenix</span
                >
            </div>
        </footer>

        <style>
            /* ── Reset ──────────────────────────────────────── */
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            /* ── Tokens ─────────────────────────────────────── */
            :root {
                --kings-red: #d6001c;
                --kings-red-light: #f2e5e7;
                --canvas: #faf9f7;
                --surface: #ffffff;
                --border: #e2ddd8;
                --border-dark: #c8c2bb;

                --ink-0: #1a1614;
                --ink-1: #3d3733;
                --ink-2: #7a7470;

                --teal: #1f7a6e;
                --teal-light: #e0f0ee;

                /* Typography */
                --font-display: "Cormorant Garamond", Georgia, serif;
                --font-sans: "IBM Plex Sans", system-ui, sans-serif;
                --font-mono: "IBM Plex Mono", "Courier New", monospace;
            }

            /* ── Base ───────────────────────────────────────── */
            html {
                background-color: var(--canvas);
            }

            body {
                font-family: var(--font-sans);
                color: var(--ink-0);
                background-color: var(--canvas);
                min-height: 100svh;
                display: flex;
                flex-direction: column;
                -webkit-font-smoothing: antialiased;
            }

            .page-rule {
                height: 3px;
                background: var(--kings-red);
            }

            nav {
                border-bottom: 1px solid var(--border);
                background: var(--surface);
            }

            .nav-inner {
                max-width: 1040px;
                margin: 0 auto;
                padding: 0 var(--size-6);
                height: 56px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .nav-wordmark {
                font-family: var(--font-display);
                font-size: 1.4rem;
                font-weight: 600;
                color: var(--ink-0);
                text-decoration: none;
                letter-spacing: 0.02em;
            }

            main {
                flex: 1;
                max-width: 1040px;
                width: 100%;
                margin: 0 auto;
                padding: var(--size-12) var(--size-6) var(--size-10);
                display: flex;
                flex-direction: column;
                gap: var(--size-10);
            }

            .hero {
                max-width: 680px;
                display: flex;
                flex-direction: column;
                gap: var(--size-4);
            }

            .hero-eyebrow {
                font-family: var(--font-mono);
                font-size: 0.7rem;
                font-weight: 400;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--kings-red);
            }

            .hero-heading {
                font-family: var(--font-display);
                font-size: clamp(2.4rem, 5vw, 3.8rem);
                font-weight: 500;
                line-height: 1.12;
                color: var(--ink-0);
                letter-spacing: -0.01em;
            }

            .hero-sub {
                font-size: 0.95rem;
                font-weight: 300;
                color: var(--ink-2);
                line-height: 1.65;
                max-width: 560px;
            }

            .query-section {
                max-width: 680px;
            }

            .query-wrapper {
                display: flex;
                flex-direction: column;
                gap: var(--size-3);
                padding: var(--size-6) var(--size-7);
                background: var(--surface);
                border: 1px solid var(--border);
                border-top: 3px solid var(--kings-red);
                transition: box-shadow 0.2s;
            }

            .query-wrapper:focus-within {
                box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
            }

            .query-label {
                font-family: var(--font-mono);
                font-size: 0.65rem;
                font-weight: 500;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--kings-red);
                display: block;
            }

            .query-input-row {
                display: flex;
                align-items: center;
                gap: var(--size-4);
                border-bottom: 1px solid var(--border-dark);
                padding-bottom: var(--size-3);
                transition: border-color 0.2s;
            }

            .query-wrapper:focus-within .query-input-row {
                border-color: var(--ink-0);
            }

            #search-input {
                flex: 1;
                background: transparent;
                border: none;
                outline: none;
                font-family: var(--font-sans);
                font-size: 1.05rem;
                font-weight: 300;
                color: var(--ink-0);
                caret-color: var(--kings-red);
                min-width: 0;
            }

            #search-button {
                display: inline-flex;
                align-items: center;
                gap: var(--size-2);
                background: var(--kings-red);
                color: #ffffff;
                border: none;
                padding: var(--size-2) var(--size-4);
                font-family: var(--font-sans);
                font-size: 0.8rem;
                font-weight: 500;
                letter-spacing: 0.02em;
                cursor: pointer;
                transition: background 0.15s;
                flex-shrink: 0;
                white-space: nowrap;
            }

            .results {
                max-width: 680px;
                display: flex;
                flex-direction: column;
                gap: var(--size-5);
            }

            .results.hidden {
                display: none;
            }

            .loader {
                display: flex;
                flex-direction: column;
                gap: var(--size-3);
            }

            .loader.hidden {
                display: none;
            }

            .loader-bar {
                height: 2px;
                background: var(--border);
                position: relative;
                overflow: hidden;
            }

            .loader-progress {
                position: absolute;
                top: 0;
                left: -35%;
                width: 35%;
                height: 100%;
                background: var(--kings-red);
                animation: scan 1.3s ease-in-out infinite;
            }

            @keyframes scan {
                0% { left: -35%; }
                100% { left: 100%; }
            }

            .answer-block {
                background: var(--surface);
                border: 1px solid var(--border);
                border-left: 3px solid var(--kings-red);
                opacity: 0;
                transform: translateY(6px);
                transition: opacity 0.35s ease, transform 0.35s ease;
                display: none;
            }

            .answer-block.visible {
                opacity: 1;
                transform: translateY(0);
                display: block;
            }

            .answer-meta {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: var(--size-4) var(--size-6);
                border-bottom: 1px solid var(--border);
                background: var(--canvas);
            }

            .answer-meta-left {
                display: flex;
                align-items: center;
                gap: var(--size-3);
            }

            .answer-meta-right {
                display: flex;
                align-items: center;
                gap: var(--size-4);
            }

            .feedback-tools {
                display: flex;
                align-items: center;
                gap: var(--size-2);
                margin-right: var(--size-2);
            }

            .feedback-btn {
                background: none;
                border: 1px solid var(--border);
                border-radius: 4px;
                padding: 4px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                color: var(--ink-2);
                transition: all 0.15s;
                opacity: 0.6;
            }

            .feedback-btn:hover {
                opacity: 1;
                background: var(--kings-red-light);
                border-color: var(--kings-red);
                color: var(--kings-red);
            }

            .feedback-btn.active {
                opacity: 1;
                background: var(--kings-red-light);
                border-color: var(--kings-red);
                color: var(--kings-red);
                box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);
            }

            .feedback-sep {
                width: 1px;
                height: 14px;
                background: var(--border);
                margin: 0 2px;
            }

            .timing-breakdown {
                display: flex;
                align-items: center;
                gap: var(--size-2);
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--ink-2);
                font-weight: 300;
                background: var(--kings-red-light);
                padding: 2px var(--size-2);
                border-radius: 4px;
            }

            .timing-breakdown.hidden {
                display: none;
            }

            .timing-sep {
                opacity: 0.3;
            }

            .answer-tag {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                font-weight: 500;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: var(--kings-red);
            }

            .cache-badge {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                font-weight: 400;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                padding: 2px var(--size-2);
                border: 1px solid;
            }

            .cache-badge.hidden {
                display: none;
            }

            .cache-badge--cached {
                color: var(--teal);
                border-color: var(--teal);
                background: var(--teal-light);
            }

            .cache-badge--fresh {
                color: var(--ink-2);
                border-color: var(--border-dark);
            }

            .cache-date {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--ink-2);
                font-weight: 300;
            }

            .cache-date.hidden { display: none; }

            .query-time {
                font-family: var(--font-mono);
                font-size: 0.65rem;
                color: var(--ink-2);
                font-weight: 300;
            }

            .answer-content {
                font-family: var(--font-display);
                font-size: 1.2rem;
                font-weight: 400;
                line-height: 1.75;
                color: var(--ink-0);
                padding: var(--size-7) var(--size-6);
            }

            /* Markdown Styling */
            .markdown-body h1, .markdown-body h2, .markdown-body h3 {
                margin-top: 1.5rem;
                margin-bottom: 1rem;
                font-family: var(--font-sans);
                font-weight: 600;
                color: var(--kings-red);
            }
            .markdown-body h1 { font-size: 1.4rem; }
            .markdown-body h2 { font-size: 1.2rem; }
            .markdown-body h3 { font-size: 1.1rem; }
            
            .markdown-body p { margin-bottom: 1.25rem; }
            
            .markdown-body ul, .markdown-body ol {
                margin-bottom: 1.25rem;
                padding-left: 1.5rem;
            }
            
            .markdown-body li { margin-bottom: 0.5rem; }
            
            .markdown-body a {
                color: var(--kings-red);
                text-decoration: underline;
                text-underline-offset: 2px;
            }
            
            .markdown-body code {
                font-family: var(--font-mono);
                font-size: 0.9rem;
                background: var(--canvas);
                padding: 2px 4px;
                border-radius: 4px;
            }

            .answer-footer {
                padding: 0;
                border-top: 1px solid var(--border);
                background: var(--canvas);
                display: none;
            }

            .answer-footer.visible {
                display: block;
            }

            .sources-toggle {
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: var(--size-3) var(--size-6);
                background: none;
                border: none;
                cursor: pointer;
                text-align: left;
            }

            .sources-toggle:hover {
                background: rgba(0,0,0,0.02);
            }

            .sources-toggle-label {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--ink-2);
                font-weight: 500;
                letter-spacing: 0.1em;
                text-transform: uppercase;
            }

            .sources-toggle-icon {
                font-size: 0.6rem;
                color: var(--ink-2);
                transition: transform 0.2s;
            }

            .sources-toggle-icon.expanded {
                transform: rotate(180deg);
            }

            .sources-list {
                display: flex;
                flex-wrap: wrap;
                gap: var(--size-3);
                padding: 0 var(--size-6);
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.3s ease-out, padding 0.3s;
            }

            .sources-list.expanded {
                max-height: 500px;
                padding: 0 var(--size-6) var(--size-6);
            }

            .source-link {
                display: inline-flex;
                align-items: center;
                gap: var(--size-2);
                padding: 4px var(--size-3);
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 4px;
                text-decoration: none !important;
                color: var(--ink-1) !important;
                font-family: var(--font-sans);
                font-size: 0.75rem;
                transition: all 0.15s;
                position: relative;
                z-index: 20;
            }

            .source-link:hover {
                border-color: var(--kings-red) !important;
                color: var(--kings-red) !important;
                transform: translateY(-1px);
                box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            }

            .source-icon { font-size: 0.9rem; }

            .answer-content.error {
                font-family: var(--font-mono);
                font-size: 0.8rem;
                color: var(--kings-red);
                font-weight: 300;
            }

            .site-footer {
                border-top: 1px solid var(--border);
                background: var(--surface);
                margin-top: auto;
            }

            .footer-inner {
                max-width: 1040px;
                margin: 0 auto;
                padding: var(--size-4) var(--size-6);
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .footer-brand {
                font-family: var(--font-display);
                font-size: 0.9rem;
                color: var(--ink-1);
                font-style: italic;
            }

            .footer-stack {
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--ink-2);
                letter-spacing: 0.1em;
                text-transform: uppercase;
                font-weight: 300;
            }

            @media (max-width: 640px) {
                main { padding: var(--size-8) var(--size-4) var(--size-8); gap: var(--size-8); }
                .hero-sub .break { display: none; }
                .query-wrapper { padding: var(--size-5) var(--size-5); }
                .query-input-row { flex-wrap: wrap; gap: var(--size-3); }
                #search-button { width: 100%; justify-content: center; padding: var(--size-3); }
                .footer-inner { flex-direction: column; gap: var(--size-2); text-align: center; }
            }
        </style>

        <script>
            import { marked } from 'marked';

            const PLACEHOLDERS = [
                "What is the current status of the Musical Lives project?",
                "Which GitHub repositories are linked to the Sudan Memory project?",
                "Who is leading the Enlightenment Architectures project?",
                "What tasks are open in the Digital Humanities sprint?",
                "Summarise recent commits to the klippy repository.",
                "Which projects are due to end this year?",
                "What are the main research themes across active projects?",
            ];

            const searchInput = document.getElementById("search-input") as HTMLInputElement;
            const searchButton = document.getElementById("search-button") as HTMLButtonElement;
            const resultsSection = document.getElementById("results-section") as HTMLElement;
            const loader = document.getElementById("loader") as HTMLElement;
            const answerBlock = document.getElementById("answer-block") as HTMLElement;
            const answerContent = document.getElementById("answer-content") as HTMLElement;
            const answerFooter = document.getElementById("answer-footer") as HTMLElement;
            const sourcesContainer = document.getElementById("sources-container") as HTMLElement;
            const sourcesToggle = document.getElementById("sources-toggle") as HTMLButtonElement;
            const sourcesToggleIcon = document.getElementById("sources-toggle-icon") as HTMLElement;
            const cacheBadge = document.getElementById("cache-badge") as HTMLElement;
            const cacheDate = document.getElementById("cache-date") as HTMLElement;
            const ellipsis = document.getElementById("ellipsis") as HTMLElement;
            const queryTime = document.getElementById("query-time") as HTMLElement;
            const timingBreakdown = document.getElementById("timing-breakdown") as HTMLElement;
            const retrievalTime = document.getElementById("retrieval-time") as HTMLElement;
            const synthesisTime = document.getElementById("synthesis-time") as HTMLElement;
            const loaderVerb = document.getElementById("loader-verb") as HTMLElement;
            const thumbsUp = document.getElementById("thumbs-up") as HTMLButtonElement;
            const thumbsDown = document.getElementById("thumbs-down") as HTMLButtonElement;
            const refreshQuery = document.getElementById("refresh-query") as HTMLButtonElement;

            let currentQuery = "";

            function rotatePlaceholder() {
                let current = 0;
                let charIndex = 0;
                let isDeleting = false;
                let isPaused = false;

                function tick() {
                    if (document.activeElement === searchInput) return;
                    const target = PLACEHOLDERS[current];
                    if (isPaused) return;

                    if (!isDeleting) {
                        searchInput.placeholder = target.slice(0, ++charIndex);
                        if (charIndex === target.length) {
                            isPaused = true;
                            setTimeout(() => { isPaused = false; isDeleting = true; tick(); }, 2800);
                            return;
                        }
                        setTimeout(tick, 38);
                    } else {
                        searchInput.placeholder = target.slice(0, --charIndex);
                        if (charIndex === 0) {
                            isDeleting = false;
                            current = (current + 1) % PLACEHOLDERS.length;
                            setTimeout(tick, 400);
                            return;
                        }
                        setTimeout(tick, 18);
                    }
                }
                setTimeout(tick, 600);
            }

            rotatePlaceholder();

            const LOADER_VERBS = ["Transcribing", "Annotating", "Collating", "Paleographing", "Hermeneuticising", "Disambiguating", "Contextualising", "Cross-referencing", "Lemmatising", "Deciphering", "Indexing", "Triangulating"];
            let loaderVerbInterval: any = null;
            let ellipsisInterval: any = null;

            function startLoadingEffects() {
                let i = Math.floor(Math.random() * LOADER_VERBS.length);
                loaderVerb.textContent = LOADER_VERBS[i];
                loaderVerbInterval = setInterval(() => {
                    i = (i + 1) % LOADER_VERBS.length;
                    loaderVerb.textContent = LOADER_VERBS[i];
                }, 3000);

                let count = 0;
                ellipsisInterval = setInterval(() => {
                    count = (count + 1) % 4;
                    ellipsis.textContent = ".".repeat(count);
                }, 380);
            }

            function stopLoadingEffects() {
                clearInterval(loaderVerbInterval);
                clearInterval(ellipsisInterval);
                ellipsis.textContent = "";
            }

            function resetResults() {
                answerBlock.classList.remove("visible");
                answerBlock.style.display = "none";
                answerFooter.classList.remove("visible");
                answerContent.innerHTML = "";
                answerContent.classList.remove("error");
                sourcesContainer.innerHTML = "";
                sourcesContainer.classList.remove("expanded");
                sourcesToggleIcon.classList.remove("expanded");
                cacheBadge.className = "cache-badge hidden";
                cacheDate.classList.add("hidden");
                queryTime.textContent = "";
                timingBreakdown.classList.add("hidden");
                thumbsUp.classList.remove("active");
                thumbsDown.classList.remove("active");
            }

            async function handleSearch(ignoreCache = false) {
                const query = searchInput.value.trim();
                if (!query) return;
                currentQuery = query;

                if (ignoreCache) {
                    // Manual refresh: clear cache first
                    await sendFeedback(false, true); 
                }

                resetResults();
                resultsSection.classList.remove("hidden");
                loader.classList.remove("hidden");
                startLoadingEffects();

                const startTime = Date.now();

                try {
                    const response = await fetch("http://localhost:8000/query", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ text: query }),
                    });

                    if (!response.ok) {
                        const errorBody = await response.text();
                        throw new Error(`Backend returned ${response.status}: ${errorBody}`);
                    }

                    const data = await response.json();
                    const elapsed = Date.now() - startTime;

                    stopLoadingEffects();
                    loader.classList.add("hidden");

                    answerBlock.style.display = "block";
                    void answerBlock.offsetHeight;
                    answerBlock.classList.add("visible");

                    if (data.cached) {
                        cacheBadge.textContent = "⚡ Cached";
                        cacheBadge.className = "cache-badge cache-badge--cached";
                        cacheBadge.classList.remove("hidden");
                        
                        if (data.cached_at) {
                            const date = new Date(data.cached_at);
                            cacheDate.textContent = `at ${date.toLocaleTimeString()} on ${date.toLocaleDateString()}`;
                            cacheDate.classList.remove("hidden");
                        }
                    } else {
                        cacheBadge.textContent = "Fresh";
                        cacheBadge.className = "cache-badge cache-badge--fresh";
                        cacheBadge.classList.remove("hidden");
                    }

                    queryTime.textContent = `${elapsed}ms`;
                    
                    if (data.retrieval_time_ms || data.synthesis_time_ms) {
                        retrievalTime.textContent = data.retrieval_time_ms.toString();
                        synthesisTime.textContent = data.synthesis_time_ms.toString();
                        timingBreakdown.classList.remove("hidden");
                    }

                    answerContent.innerHTML = await marked.parse(data.answer);

                    if (data.sources && data.sources.length > 0) {
                        const uniqueSources = new Map();
                        data.sources.forEach((s: any) => {
                            if (s.url && !uniqueSources.has(s.url)) {
                                uniqueSources.set(s.url, s);
                            }
                        });

                        if (uniqueSources.size > 0) {
                            answerFooter.classList.add("visible");
                            uniqueSources.forEach((s: any) => {
                                const icon = s.source === 'github' ? '<span class="source-icon">🐙</span>' : '';
                                const link = document.createElement('a');
                                link.href = s.url;
                                link.target = "_blank";
                                link.rel = "noopener noreferrer";
                                link.className = "source-link";
                                link.innerHTML = `${icon}<span class="source-title">${s.title.replace('.md', '')}</span>`;
                                sourcesContainer.appendChild(link);
                            });
                        }
                    }
                    
                } catch (error: any) {
                    const elapsed = Date.now() - startTime;
                    stopLoadingEffects();
                    loader.classList.add("hidden");
                    answerBlock.style.display = "block";
                    void answerBlock.offsetHeight;
                    answerBlock.classList.add("visible");
                    answerContent.classList.add("error");
                    
                    const message = error.message || "Unknown error";
                    answerContent.textContent = `Error: ${message}.`;
                    queryTime.textContent = `${elapsed}ms`;
                    console.error("Search Error:", error);
                }
            }

            async function sendFeedback(isPositive: boolean, silent = false) {
                if (!currentQuery) return;
                
                if (!silent) {
                    const btn = isPositive ? thumbsUp : thumbsDown;
                    btn.classList.add("active");
                }
                
                try {
                    await fetch("http://localhost:8000/feedback", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ text: currentQuery, is_positive: isPositive }),
                    });
                    
                    if (!isPositive && !silent) {
                        alert("Feedback noted. Cache cleared for this query.");
                    }
                } catch (error) {
                    console.error("Feedback error:", error);
                }
            }

            sourcesToggle.addEventListener("click", () => {
                const isExpanded = sourcesContainer.classList.toggle("expanded");
                sourcesToggleIcon.classList.toggle("expanded", isExpanded);
            });

            thumbsUp.addEventListener("click", () => sendFeedback(true));
            thumbsDown.addEventListener("click", () => sendFeedback(false));
            refreshQuery.addEventListener("click", () => handleSearch(true));

            searchButton.addEventListener("click", () => handleSearch());
            searchInput.addEventListener("keydown", (e: KeyboardEvent) => {
                if (e.key === "Enter") handleSearch();
            });
        </script>
    </body>
</html>
