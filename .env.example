# LLM Configuration (OpenAI or compatible like LocalAI, vLLM, Ollama)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo-preview
EMBED_MODEL=text-embedding-3-small
EMBED_DEVICE=cpu # Use 'mps' for Apple Silicon, 'cuda' for NVIDIA, or 'cpu'

# ClickUp Credentials
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_WORKSPACE_ID=your_workspace_id_here
CLICKUP_IGNORE_SPACES=Space1,Space2

# GitHub Credentials
GITHUB_TOKEN=your_github_token_here
GITHUB_ORGS=org1,org2
GITHUB_USERS=user1,user2
GITHUB_IGNORE_REPOS=org/repo1,org/repo2

# Infrastructure (override when running outside Docker)
QDRANT_HOST=localhost
REDIS_HOST=localhost
REDIS_PORT=6379
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Application Settings
PUBLIC_API_URL=http://localhost:8000
DATA_DIR=./data/raw
STATE_FILE=./data/state.json
LOG_LEVEL=INFO
